{
  "name": "std-semver",
  "type": "module",
  "version": "0.0.0",
  "packageManager": "npm@11.11.0",
  "description": "npm port of @std/semver",
  "license": "MIT",
  "homepage": "https://github.com/sxzz/std-semver#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sxzz/std-semver.git"
  },
  "bugs": {
    "url": "https://github.com/sxzz/std-semver/issues"
  },
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "lint": "eslint --cache .",
    "lint:fix": "npm run lint --fix",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsgo --noEmit",
    "format": "prettier --cache --write .",
    "release": "bumpp",
    "prepublishOnly": "npm run build"
  },
  "inlinedDependencies": {
    "@jsr/std__semver": "1.0.8"
  },
  "devDependencies": {
    "@std/semver": "jsr:@std/semver@^1.0.8",
    "@sxzz/eslint-config": "^7.8.3",
    "@sxzz/prettier-config": "^2.3.1",
    "@types/node": "^25.3.5",
    "@typescript/native-preview": "7.0.0-dev.20260309.1",
    "bumpp": "^10.4.1",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "tsdown": "^0.21.1",
    "tsdown-preset-sxzz": "^0.4.1",
    "typescript": "^5.9.3"
  },
  "prettier": "@sxzz/prettier-config"
}
